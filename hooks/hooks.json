{
  "description": "Claude Code 通知 Hooks - 任务完成/停止时推送消息到钉钉或飞书",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|request_permission",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
