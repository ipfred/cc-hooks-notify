{
  "description": "通知 Hooks - 任务停止或权限请求时推送消息到钉钉或飞书",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|request_permission|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "cc-notify hook claude",
            "timeout": 10,
            "statusMessage": "cc-notify sending"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cc-notify hook codex",
            "timeout": 10,
            "statusMessage": "cc-notify sending"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cc-notify hook claude",
            "timeout": 10,
            "statusMessage": "cc-notify sending"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cc-notify hook claude",
            "timeout": 10,
            "statusMessage": "cc-notify sending"
          }
        ]
      }
    ]
  }
}
