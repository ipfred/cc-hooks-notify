# cc-hooks-notify 配置文件模板
# 复制此文件为 config.yaml 并填入你的配置

# 日志级别: DEBUG, INFO, WARN, ERROR
log_level: INFO

# 日志目录（可选，默认项目根目录下的 logs/）
# log_dir: "/path/to/your/logs"

# 通知渠道配置
channels:
  dingtalk:
    enabled: false
    webhook: "https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"
    secret: ""                    # 可选：钉钉安全设置的加签密钥
    markdown: true                # false 则使用纯文本发送（解决部分乱码问题）

  feishu:
    enabled: false
    webhook: "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK"
    secret: ""                    # 可选：飞书安全设置的加签密钥
    card: true                    # false 则使用纯文本发送

# 事件级别配置（可选）
# 若未指定 channels，则默认使用所有 enabled=true 的渠道
events:
  notification:
    # 示例：仅钉钉接收通知
    channels: ["dingtalk"]

  stop:
    # 示例：仅飞书接收完成通知
    channels: ["feishu"]
